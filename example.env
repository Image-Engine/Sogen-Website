# =============================================================================
# Sogen Energy — environment variables
# =============================================================================
#
# Copy for local development:
#   cp example.env .env
#
# Variable types:
#   NEXT_PUBLIC_*  → exposed to the browser (safe for public values only)
#   (no prefix)    → server-only; used by /api/* routes on Vercel or `npm run dev`
#
# Backend: Next.js API routes (no Supabase)
#   POST /api/shopify-oauth   → customer login, orders, addresses
#   GET  /api/google-reviews  → homepage testimonials
#
# Shopify Storefront + Blog API tokens are hardcoded in src/lib/shopify.ts
# (products, cart, checkout, blog content — no env vars needed).
# =============================================================================

# -----------------------------------------------------------------------------
# Optional — site URLs (defaults match production in src/lib/blogUrls.ts)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_MAIN_SITE_URL=https://sogenenergy.co.nz
NEXT_PUBLIC_BLOG_SITE_URL=https://blog.sogenenergy.co.nz

# OAuth redirect base when not running in a browser (SSR fallback)
# NEXT_PUBLIC_SITE_URL=https://sogenenergy.co.nz

# Simulate blog.sogenenergy.co.nz on localhost:8080 (src/middleware.ts)
# NEXT_PUBLIC_BLOG_HOST_DEV=true

# -----------------------------------------------------------------------------
# Optional — Playwright E2E
# -----------------------------------------------------------------------------

# PLAYWRIGHT_BASE_URL=http://localhost:8080

# =============================================================================
# Server-only — Shopify Customer Account API
# Required for /account/login, orders, addresses, profile (name only)
# Set in .env locally AND in Vercel → Settings → Environment Variables
# =============================================================================
#
# Get from Shopify Admin → Sales channels → Headless → Customer Account API
# Redirect URIs must include:
#   https://sogenenergy.co.nz/auth/callback
#   http://localhost:8080/auth/callback
#
SHOPIFY_CUSTOMER_API_CLIENT_ID=your-customer-account-client-id
SHOPIFY_CUSTOMER_API_CLIENT_SECRET=your-customer-account-client-secret
SHOPIFY_STORE_DOMAIN=sokbattery-frontline-shine-zq4jf.myshopify.com

# =============================================================================
# Server-only — Google Business reviews (homepage testimonials)
# Optional — without these, /api/google-reviews returns empty + fallback UI
# =============================================================================
#
# GOOGLE_SERVICE_ACCOUNT_JSON must be a single-line JSON string in .env, e.g.:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}
#
# GOOGLE_BUSINESS_ACCOUNT_ID=123456789012345678901
# GOOGLE_BUSINESS_LOCATION_ID=987654321098765432109

# =============================================================================
# Minimal local .env (storefront only — no account login or live reviews)
# =============================================================================
#
# Leave server vars unset. Products, cart, blog, and static pages still work.
# /account/login will fail until SHOPIFY_CUSTOMER_API_* vars are set.
#
